{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SVoice 3",
  "version": "0.1.2",
  "identifier": "se.stegberg.svoice.v3",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SVoice",
        "width": 1280,
        "height": 880,
        "minWidth": 1040,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "src/overlays/overlay.html",
        "width": 200,
        "height": 56,
        "x": 0,
        "y": 0,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "visible": true
      },
      {
        "label": "action-popup",
        "url": "src/overlays/action-popup.html",
        "width": 620,
        "height": 420,
        "center": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "visible": false
      },
      {
        "label": "palette",
        "url": "src/palette/palette.html",
        "width": 520,
        "height": 440,
        "center": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' asset: data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "category": "Productivity",
    "shortDescription": "Svensk diktering för Windows",
    "resources": {
      "resources/python-runtime": "python-runtime",
      "resources/python/stt_sidecar.py": "python/stt_sidecar.py"
    }
  },
  "plugins": {}
}
